@inproceedings{wang2024mlperf,
  abbr      = {PEARC},
  title     = {Preliminary Results of the MLPerf BERT Inference Benchmark on AMD Instinct GPUs},
  author    = {Wang, Zixian and Vu, Khai and Hodak, Miro and Mehrotra, Aarush and Gutierrez, Francisco and Smith, Kyle and Seo, Gloria and Garcia, Austin and Chin, Bryan and Kandes, Marty and Thomas, Mary P.},
  abstract  = {In recent years, Artificial Intelligence (AI) has reshaped various facets of our day-to-day lives. To evaluate both hardware and software deployment of Machine Learning (ML) applications, it is necessary to measure system-wide performance and accuracy. MLPerf, a Machine Learning Benchmark from MLCommons, provides a standard for measuring Machine Learning Performance on hardware. To our knowledge, there is little known public effort on porting and optimizing these inference benchmark models on AMD GPUs. This paper focuses on the effort to port MLPerf BERT, one of the MLPerf Inference Benchmarks, to run on AMD Instinct MI210 and MI250 Accelerators. We describe the challenges encountered, solutions applied, and the successful porting of the benchmark resulting in submission of the code to the MLPerf community codebase.},
  booktitle = {Practice and Experience in Advanced Research Computing 2024: Human Powered Computing},
  pages     = {1--5},
  numpages  = {5},
  year      = {2024},
  month     = {July},
  publisher = {ACM},
  doi       = {10.1145/3626203.3670589},
  url       = {https://dl.acm.org/doi/abs/10.1145/3626203.3670589},
  pdf       = {https://dl.acm.org/doi/pdf/10.1145/3626203.3670589},
  selected  = {true}
}

@article{wang2025critique,
  abbr      = {IEEE TPDS},
  title     = {Critique of "Data Flow Lifecycles for Optimizing Workflow Coordination" by SCC Team From UC San Diego},
  author    = {Wang, Shijie and Gutierrez, Francisco and Wang, Zixian and Feng, Zhiheng and Renjith, Gauri and Mehrotra, Aarush and Chin, Bryan and Kandes, Marty and Thomas, Mary},
  abstract  = {Reproducibility remains a critical challenge in high-performance computing (HPC), where increasing system complexity and evolving software stacks often impede the validation of published results. This work, conducted as part of the Student Cluster Competition (SCC) 2024 Reproducibility Challenge at SC24 in Atlanta, targets this issue by reproducing key findings from Data Flow Lifecycles for Optimizing Workflow Coordination. The target paper introduces Data Flow Lifecycles (DFL), a methodology for optimizing data-intensive scientific workflows. We replicate the original experiments on SCC24 competition hardware with AMD EPYC 9634 CPU, utilizing RAM-disk and SSD-based staging. Our results successfully reproduce the original qualitative trends and demonstrate a performance speedup with these optimizations. However, quantitative results diverge by 50--62.5%, primarily due to differences in cluster configuration.},
  journal   = {IEEE Transactions on Parallel and Distributed Systems},
  year      = {2025},
  month     = {December},
  publisher = {IEEE},
  doi       = {10.1109/TPDS.2025.3648438},
  url       = {https://ieeexplore.ieee.org/abstract/document/11315875/},
  selected  = {true}
}